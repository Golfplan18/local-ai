{
  "manifest_version": 3,
  "name": "Ora Browser Bridge",
  "version": "1.0.0",
  "description": "Connects your AI subscriptions to the Ora orchestrator for browser-based evaluations.",
  "permissions": [
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://chat.mistral.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://grok.com/*",
    "https://poe.com/*",
    "https://huggingface.co/*",
    "https://www.meta.ai/*",
    "https://coral.cohere.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
