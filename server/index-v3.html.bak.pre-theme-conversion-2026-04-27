<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Ora — v3 mockup</title>
<style>
  :root {
    /* ── DARK MODE (DEFAULT) — baseline palette ─────
       Light mode (body.light-theme, defined below) inverts every value
       below by subtracting each from 256. ────────── */
    --interface-bg:        rgb(16,  16,  16);   /* #101010 — outer canvas */
    --pane-output-bg:      rgb(32,  32,  32);   /* #202020 — left output + right canvas */
    --pane-input-bg:       rgb(48,  48,  48);   /* #303030 — input box, brighter */
    --pane-border:         rgb(64,  64,  64);   /* #404040 — pane outlines */
    --line-dot-color:      rgb(56,  56,  56);   /* #383838 — rule lines + dot grid */

    --button-interior:     rgb(24,  24,  24);   /* #181818 — icon-button fill */
    --button-border:       rgb(32,  32,  32);   /* #202020 — icon-button outline */
    --button-icon:         rgb(64,  64,  64);   /* #404040 — icon glyph at rest */
    --button-icon-hover:   rgb(160, 160, 160);  /* hover brightening (glyph + border together) */

    --wm-base:             rgb(88,  88,  88);   /* #585858 — O outer + r + a stem */
    --wm-bright:           rgb(128, 128, 128);  /* #808080 — O inner + a ring */
    --wm-hover:            rgb(220, 220, 220);  /* hover brightening for clickable letters */

    --text-input-color:    rgb(220, 220, 220);  /* user-typed text in any input pane */

    --bridge-handle:       rgba(255, 255, 255, 0.18);
    --shadow-recess:       rgba(0,   0,   0,   0.65);
    --shadow-raised:       rgba(0,   0,   0,   0.55);
    --highlight-recess:    rgba(255, 255, 255, 0.04);
    --highlight-raised:    rgba(255, 255, 255, 0.05);
    --focus-ring:          rgba(255, 255, 255, 0.35);

    --grid-step:           24px;
    --bridge-default:      48px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--interface-bg);
    color: var(--button-icon);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
    overflow: hidden;
  }

  button { font: inherit; color: inherit; background: none; border: none; }

  /* ── Shell layout ──────────────────────────────────── */
  .ora-shell {
    display: grid;
    grid-template-columns: 1fr 68px 1fr;
    gap: 14px;
    padding: 16px;
    height: 100vh;
  }

  /* ── Left column: input on top, bridge strip, output on bottom ── */
  .left-column {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* ── Right column: chat input → small gap → chat output → big bridge gap → visual canvas
        Mirrors the left structure at the bridge level — the big right gap and the
        left bridge stay locked together (both follow the wordmark r-center). The
        smaller chatbot-internal gap moves independently. ── */
  .right-column {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .chat-zone {
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    min-height: 0;
    /* height set by JS to match left input pane, so the big right gap aligns
       with the left bridge */
  }

  /* ── Pane (recessed surface) ───────────────────────── */
  .pane {
    background: var(--pane-output-bg);
    border: 2px solid var(--pane-border);
    border-radius: 6px;
    box-shadow:
      inset 5px 5px 12px var(--shadow-recess),
      inset -1px -1px 0 var(--highlight-recess);
    overflow: hidden;
    position: relative;
    transition: border-color 0.2s;
  }

  .input-pane {
    height: 120px;
    flex-shrink: 0;
    padding: 14px 18px;
    background: var(--pane-input-bg);
  }
  .input-pane textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    color: var(--text-input-color);
    font-family: inherit;
    font-size: 14px;
    line-height: 1.5;
  }

  .output-pane {
    flex: 1;
    min-height: 0;
  }
  .output-pane::before {
    content: '';
    position: absolute;
    left: 10%;
    right: 10%;
    top: 10%;
    bottom: 10%;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent calc(var(--grid-step) - 1px),
      var(--line-dot-color) calc(var(--grid-step) - 1px),
      var(--line-dot-color) var(--grid-step)
    );
    pointer-events: none;
  }

  .right-pane {
    flex: 1;
    min-height: 0;
    background-image:
      radial-gradient(var(--line-dot-color) 1.4px, transparent 1.6px);
    background-size: var(--grid-step) var(--grid-step);
    background-position: 12px 12px;
  }

  /* ── Chatbot panes (right column) ── */
  .chat-input-pane {
    height: 80px;        /* default; controlled by chatbot-divider drag */
    flex-shrink: 0;
    padding: 14px 18px;
    background: var(--pane-input-bg);
  }
  .chat-input-pane textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    color: var(--text-input-color);
    font-family: inherit;
    font-size: 14px;
    line-height: 1.5;
  }

  .chat-output-pane {
    flex: 1;
    min-height: 0;
  }

  /* Small draggable separator inside the chatbot zone */
  .chatbot-divider {
    height: 18px;
    flex-shrink: 0;
    cursor: ns-resize;
    position: relative;
  }
  .chatbot-divider::after {
    content: '';
    position: absolute;
    left: 35%;
    right: 35%;
    top: 0;
    height: 2px;
    border-radius: 0 0 1px 1px;
    background: var(--bridge-handle);
    opacity: 0.50;
    transition: opacity 0.12s, height 0.12s, left 0.12s, right 0.12s;
  }
  .chatbot-divider:hover::after,
  body.chat-dragging .chatbot-divider::after {
    opacity: 0.95;
    height: 3px;
    left: 30%;
    right: 30%;
  }
  body.chat-dragging {
    cursor: ns-resize;
    user-select: none;
  }

  /* Big draggable gap on the right — mirrors the left bridge in dimensions
     and behavior; both bridges and the wordmark r-center move together. */
  .bridge-strip-right {
    height: var(--bridge-default);
    flex-shrink: 0;
    cursor: ns-resize;
    position: relative;
  }
  .bridge-strip-right::after {
    content: '';
    position: absolute;
    left: 35%;
    right: 35%;
    top: 0;
    height: 2px;
    border-radius: 0 0 1px 1px;
    background: var(--bridge-handle);
    opacity: 0.50;
    transition: opacity 0.12s, height 0.12s, left 0.12s, right 0.12s;
  }
  .bridge-strip-right:hover::after,
  body.dragging .bridge-strip-right::after {
    opacity: 0.95;
    height: 3px;
    left: 30%;
    right: 30%;
  }

  /* ── Bridge strip (between input and output, draggable) ── */
  .bridge-strip {
    height: var(--bridge-default);
    flex-shrink: 0;
    cursor: ns-resize;
    position: relative;
  }
  .bridge-strip::after {
    content: '';
    position: absolute;
    left: 35%;
    right: 35%;
    top: 0;
    height: 2px;
    border-radius: 0 0 1px 1px;
    background: var(--bridge-handle);
    opacity: 0.50;
    transition: opacity 0.12s, height 0.12s, left 0.12s, right 0.12s;
  }
  .bridge-strip:hover::after,
  body.dragging .bridge-strip::after {
    opacity: 0.95;
    height: 3px;
    left: 30%;
    right: 30%;
  }
  body.dragging {
    cursor: ns-resize;
    user-select: none;
  }

  /* ── Spine: padding 0 so icon clusters align flush with pane top/bottom ── */
  .spine {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  .spine-top, .spine-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .spine-bottom { margin-top: auto; }

  /* ── Spine icon buttons (raised) ───────────────────── */
  .spine-button {
    width: 44px;
    height: 44px;
    border-radius: 9px;
    background: var(--button-interior);
    border: 1px solid var(--button-border);
    color: var(--button-icon);
    box-shadow:
      3px 4px 6px var(--shadow-raised),
      inset 1px 1px 0 var(--highlight-raised);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.12s, border-color 0.12s, transform 0.08s, box-shadow 0.08s;
  }
  .spine-button:hover {
    color: var(--button-icon-hover);
    border-color: var(--button-icon-hover);
  }
  .spine-button:active {
    transform: translate(1px, 1px);
    box-shadow:
      2px 2px 4px var(--shadow-raised),
      inset 1px 1px 0 var(--highlight-raised);
  }
  .spine-button svg { width: 22px; height: 22px; display: block; }

  /* ── Vertical wordmark — r-center stays anchored to bridge-strip center.
        JS sets `top` to the bridge's vertical midpoint; transform shifts the
        wordmark up by the r-center's offset (55.34% of height) so the r lands
        on that midpoint. ── */
  .spine-wordmark {
    position: absolute;
    top: 0;
    left: 50%;
    width: 60px;
    height: auto;
    transform: translate(-50%, -55.34%);
  }
  .wm-stroke-base   { stroke: var(--wm-base);   fill: none; transition: stroke 0.12s; }
  .wm-stroke-bright { stroke: var(--wm-bright); fill: none; transition: stroke 0.12s; }
  .wm-fill-base     { fill: var(--wm-base);     stroke: none; transition: fill 0.12s; }

  .wordmark-clickable { cursor: pointer; }
  .wordmark-clickable:focus-visible { outline: none; }

  .wordmark-clickable:hover .wm-stroke-base,
  .wordmark-clickable:focus-visible .wm-stroke-base   { stroke: var(--wm-hover); }
  .wordmark-clickable:hover .wm-stroke-bright,
  .wordmark-clickable:focus-visible .wm-stroke-bright { stroke: var(--wm-hover); }
  .wordmark-clickable:hover .wm-fill-base,
  .wordmark-clickable:focus-visible .wm-fill-base     { fill:   var(--wm-hover); }

  /* ── Focus accessibility ───────────────────────────── */
  button:focus-visible, textarea:focus-visible {
    outline: 1px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* ── Mode label in bridge strip — right-justified near the R ── */
  .bridge-mode-label {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.04em;
    white-space: nowrap;
    pointer-events: none;
    display: none;
  }

  /* ── Help mode: +64 GREEN channel only on help button + all pane borders ── */
  body.help-mode {
    --pane-border: rgb(64, 128, 64);
  }
  body.help-mode .spine-button[data-mode-button="help"],
  body.help-mode .spine-button[data-mode-button="help"]:hover {
    border-color: rgb(32, 96, 32);
    color: rgb(64, 128, 64);
  }
  body.help-mode .bridge-mode-label {
    display: block;
    color: rgb(32, 96, 32);
  }

  /* ── Stealth mode: +96 RED channel only on stealth button + all pane borders ── */
  body.stealth-mode {
    --pane-border: rgb(160, 64, 64);
  }
  body.stealth-mode .spine-button[data-mode-button="stealth"],
  body.stealth-mode .spine-button[data-mode-button="stealth"]:hover {
    border-color: rgb(128, 32, 32);
    color: rgb(160, 64, 64);
  }
  body.stealth-mode .bridge-mode-label {
    display: block;
    color: rgb(128, 32, 32);
  }

  /* ── Bottom-cluster button modes: +32 BLUE channel only on that button's
        border, glyph, and all pane borders. No bridge-strip label.
        Mutually exclusive with each other and with help/stealth. ── */
  body.cmd-mode,
  body.menu-mode,
  body.config-mode,
  body.stats-mode {
    --pane-border: rgb(64, 64, 96);
  }
  body.cmd-mode    .spine-button[data-mode-button="cmd"],
  body.cmd-mode    .spine-button[data-mode-button="cmd"]:hover,
  body.menu-mode   .spine-button[data-mode-button="menu"],
  body.menu-mode   .spine-button[data-mode-button="menu"]:hover,
  body.config-mode .spine-button[data-mode-button="config"],
  body.config-mode .spine-button[data-mode-button="config"]:hover,
  body.stats-mode  .spine-button[data-mode-button="stats"],
  body.stats-mode  .spine-button[data-mode-button="stats"]:hover {
    border-color: rgb(32, 32, 64);
    color: rgb(64, 64, 96);
  }

  /* ─── LIGHT THEME — surface palette inverted (256 − dark), shadows kept ───
        Shadows and highlights stay as defined in :root — they belong to the
        material, not the theme. Mode tints invert their direction in light
        theme: instead of boosting one channel, the other two are reduced by
        the same amount so the same hue (green=help, red=stealth, blue=bottom)
        comes through as darker/more-saturated against the light surface. ─── */
  body.light-theme {
    --interface-bg:        rgb(240, 240, 240);
    --pane-output-bg:      rgb(224, 224, 224);
    --pane-input-bg:       rgb(208, 208, 208);
    --pane-border:         rgb(192, 192, 192);
    --line-dot-color:      rgb(200, 200, 200);

    --button-interior:     rgb(232, 232, 232);
    --button-border:       rgb(224, 224, 224);
    --button-icon:         rgb(192, 192, 192);
    --button-icon-hover:   rgb( 96,  96,  96);

    --wm-base:             rgb(168, 168, 168);
    --wm-bright:           rgb(128, 128, 128);
    --wm-hover:            rgb( 36,  36,  36);

    --bridge-handle:       rgba(  1,   1,   1, 0.18);
    --focus-ring:          rgba(  1,   1,   1, 0.35);
    --text-input-color:    rgb( 36,  36,  36);
    /* shadow-recess, shadow-raised, highlight-recess, highlight-raised
       deliberately NOT overridden — they stay at the dark-mode :root values
       so depth reads the same in both themes. */
  }

  /* Light theme + help mode (still green; reduce R and B by 64 instead of boosting G) */
  body.light-theme.help-mode { --pane-border: rgb(128, 192, 128); }
  body.light-theme.help-mode .spine-button[data-mode-button="help"],
  body.light-theme.help-mode .spine-button[data-mode-button="help"]:hover {
    border-color: rgb(160, 224, 160);
    color: rgb(128, 192, 128);
  }
  body.light-theme.help-mode .bridge-mode-label { color: rgb(160, 224, 160); }

  /* Light theme + stealth mode (still red; reduce G and B by 96 instead of boosting R) */
  body.light-theme.stealth-mode { --pane-border: rgb(192, 96, 96); }
  body.light-theme.stealth-mode .spine-button[data-mode-button="stealth"],
  body.light-theme.stealth-mode .spine-button[data-mode-button="stealth"]:hover {
    border-color: rgb(224, 128, 128);
    color: rgb(192, 96, 96);
  }
  body.light-theme.stealth-mode .bridge-mode-label { color: rgb(224, 128, 128); }

  /* Light theme + bottom-cluster modes (still blue; reduce R and G by 32 instead of boosting B) */
  body.light-theme.cmd-mode,
  body.light-theme.menu-mode,
  body.light-theme.config-mode,
  body.light-theme.stats-mode {
    --pane-border: rgb(160, 160, 192);
  }
  body.light-theme.cmd-mode    .spine-button[data-mode-button="cmd"],
  body.light-theme.cmd-mode    .spine-button[data-mode-button="cmd"]:hover,
  body.light-theme.menu-mode   .spine-button[data-mode-button="menu"],
  body.light-theme.menu-mode   .spine-button[data-mode-button="menu"]:hover,
  body.light-theme.config-mode .spine-button[data-mode-button="config"],
  body.light-theme.config-mode .spine-button[data-mode-button="config"]:hover,
  body.light-theme.stats-mode  .spine-button[data-mode-button="stats"],
  body.light-theme.stats-mode  .spine-button[data-mode-button="stats"]:hover {
    border-color: rgb(192, 192, 224);
    color: rgb(160, 160, 192);
  }
</style>
</head>
<body>

<div class="ora-shell">

  <!-- LEFT COLUMN — input on top, draggable bridge strip, output on bottom -->
  <div class="left-column">
    <div class="pane input-pane">
      <textarea spellcheck="false"></textarea>
    </div>
    <div class="bridge-strip" id="bridgeStrip" role="separator"
         aria-orientation="horizontal" aria-label="Resize input">
      <span class="bridge-mode-label" id="bridgeModeLabel"></span>
    </div>
    <div class="pane output-pane"></div>
  </div>

  <!-- SPINE — bare; icon clusters flush with pane top/bottom -->
  <div class="spine">

    <!-- TOP cluster: ? (help) at the very top, ⊘ (stealth) below it -->
    <div class="spine-top">

      <button class="spine-button" type="button" aria-label="Help"
              data-mode-button="help" id="modeBtnHelp">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2 -3 3 -3 3"/>
          <path d="M12 17h.01"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Stealth"
              data-mode-button="stealth" id="modeBtnStealth">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2">
          <circle cx="12" cy="12" r="9"/>
          <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round"/>
        </svg>
      </button>

    </div>

    <!-- Vertical wordmark — slides with the bridge strip
         O (top) = enter, r (middle) = decorative, a (bottom) = output menu
         Two color tiers:
           wm-bright (rgb 128,128,128) — O inner ring + a ring
           wm-base   (rgb  88, 88, 88) — O outer ring + r arc + r stem + a stem
         a's stem drawn before its ring so the circle is continuous
         and matches the O's inner ring exactly. -->
    <svg class="spine-wordmark" viewBox="0 0 290 842"
         xmlns="http://www.w3.org/2000/svg"
         stroke-width="18">

      <g id="logo-o" class="wordmark-letter wordmark-clickable"
         role="button" tabindex="0" aria-label="Submit">
        <circle cx="145" cy="145" r="145" fill="transparent" stroke="none"/>
        <circle cx="145" cy="145" r="136" class="wm-stroke-base"/>
        <circle cx="145" cy="145" r="91"  class="wm-stroke-bright"/>
      </g>

      <g id="logo-r" class="wordmark-letter" aria-hidden="true">
        <path d="M 54 466 A 91 91 0 0 1 236 466"
              class="wm-stroke-base" stroke-linecap="butt"/>
        <rect x="45" y="366" width="18" height="200" class="wm-fill-base"/>
      </g>

      <g id="logo-a" class="wordmark-letter wordmark-clickable"
         role="button" tabindex="0" aria-label="Output menu">
        <circle cx="145" cy="742" r="100" fill="transparent" stroke="none"/>
        <rect x="227" y="642" width="18" height="200" class="wm-fill-base"/>
        <circle cx="145" cy="742" r="91"  class="wm-stroke-bright"/>
      </g>

    </svg>

    <!-- BOTTOM cluster: +, ≡, sliders, bar chart — flush with pane bottoms -->
    <div class="spine-bottom">

      <button class="spine-button" type="button" aria-label="Command palette"
              data-mode-button="cmd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Mode selector"
              data-mode-button="menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Configuration"
              data-mode-button="config">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <circle cx="9" cy="6" r="2.4" fill="var(--button-interior)"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <circle cx="15" cy="12" r="2.4" fill="var(--button-interior)"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
          <circle cx="11" cy="18" r="2.4" fill="var(--button-interior)"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Analytics"
              data-mode-button="stats">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="6" y1="20" x2="6" y2="14"/>
          <line x1="12" y1="20" x2="12" y2="8"/>
          <line x1="18" y1="20" x2="18" y2="11"/>
          <line x1="3.5" y1="20" x2="20.5" y2="20"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- RIGHT COLUMN — chat input → small gap → chat output → big bridge gap → visual canvas
       The big right gap and the left bridge are locked together (both follow the
       wordmark r-center). The small chatbot gap is independent. -->
  <div class="right-column">
    <div class="chat-zone" id="chatZone">
      <div class="pane chat-input-pane">
        <textarea spellcheck="false"></textarea>
      </div>
      <div class="chatbot-divider" id="chatbotDivider" role="separator"
           aria-orientation="horizontal" aria-label="Resize chat input"></div>
      <div class="pane chat-output-pane"></div>
    </div>
    <div class="bridge-strip-right" id="bridgeStripRight" role="separator"
         aria-orientation="horizontal" aria-label="Resize main split"></div>
    <div class="pane right-pane"></div>
  </div>

</div>

<script>
(() => {
  // Two independent drags wired up on this page:
  //
  // 1. MAIN SPLIT — the left bridge strip and the big right gap are locked
  //    together. Dragging either one resizes the left input pane AND the right
  //    chat-zone (which sits above the big right gap) by the same amount, and
  //    moves the wordmark r-center to track them. The wordmark constraint also
  //    clamps how far either bridge can move (O top stays ≥ ICON_GAP from the
  //    top icon cluster, a bottom stays ≥ ICON_GAP from the bottom cluster).
  //
  // 2. CHATBOT SPLIT — the small divider inside the chat-zone. Dragging this
  //    only changes the chat-input pane's height; chat-output reflows. The
  //    main split, the wordmark, and the left bridge are unaffected.
  //
  const bridge          = document.getElementById('bridgeStrip');
  const bridgeRight     = document.getElementById('bridgeStripRight');
  const chatbotDivider  = document.getElementById('chatbotDivider');
  const input           = document.querySelector('.input-pane');
  const chatZone        = document.getElementById('chatZone');
  const chatInput       = document.querySelector('.chat-input-pane');
  const wordmark        = document.querySelector('.spine-wordmark');
  const spine           = document.querySelector('.spine');
  const topCluster      = document.querySelector('.spine-top');
  const bottomCluster   = document.querySelector('.spine-bottom');

  const MIN_INPUT             = 60;
  const MAX_INPUT_RATIO       = 0.7;
  const ICON_GAP              = 18;
  const R_CENTER_RATIO        = 0.5534;
  const CHAT_SMALL_GAP        = 18;
  const MIN_CHAT_INPUT        = 80;   /* leaves room for 2 rows of text inside the 14px outer padding + browser textarea padding so the scrollbar never appears at minimum */
  const MAX_CHAT_INPUT_RATIO  = 0.7;     // of the chat-zone height

  // ─── Wordmark placement: r-center pinned to left bridge center ───
  const placeWordmark = () => {
    const bRect = bridge.getBoundingClientRect();
    const sRect = spine.getBoundingClientRect();
    const bridgeCenterViewport = bRect.top + bRect.height / 2;
    wordmark.style.top = (bridgeCenterViewport - sRect.top) + 'px';
  };

  // Bounds for the main split that keep the wordmark off the icon clusters.
  const computeMainBounds = () => {
    const tcBottom = topCluster.getBoundingClientRect().bottom;
    const bcTop    = bottomCluster.getBoundingClientRect().top;
    const inputTop = input.getBoundingClientRect().top;
    const bridgeH  = bridge.getBoundingClientRect().height;
    const wmH      = wordmark.getBoundingClientRect().height;
    const minH = tcBottom + ICON_GAP + R_CENTER_RATIO * wmH - inputTop - bridgeH / 2;
    const maxH = bcTop    - ICON_GAP - (1 - R_CENTER_RATIO) * wmH - inputTop - bridgeH / 2;
    return {
      min: Math.max(MIN_INPUT, minH),
      max: Math.min(window.innerHeight * MAX_INPUT_RATIO, maxH)
    };
  };

  // Apply a new main-split height to BOTH the left input and the right chat-zone,
  // then re-clamp the chat-input height in case the chat-zone shrank below it.
  const setMainHeight = (newH) => {
    input.style.height = newH + 'px';
    chatZone.style.height = newH + 'px';
    // Re-clamp chat-input if chat-zone shrank
    const maxChatInput = Math.max(MIN_CHAT_INPUT, newH * MAX_CHAT_INPUT_RATIO - CHAT_SMALL_GAP);
    if (chatInput.offsetHeight > maxChatInput) {
      chatInput.style.height = maxChatInput + 'px';
    }
    placeWordmark();
  };

  const clampAndPlace = () => {
    const bounds  = computeMainBounds();
    const current = input.offsetHeight;
    const clamped = Math.max(bounds.min, Math.min(bounds.max, current));
    setMainHeight(clamped);
  };

  // ─── Main-split drag (either bridge) ───
  let mainDrag = false, mainStartY = 0, mainStartH = 0;

  const mainDown = (e) => {
    mainDrag    = true;
    mainStartY  = e.clientY;
    mainStartH  = input.offsetHeight;
    document.body.classList.add('dragging');
    e.preventDefault();
  };
  const mainMove = (e) => {
    if (!mainDrag) return;
    const dy     = e.clientY - mainStartY;
    const bounds = computeMainBounds();
    const newH   = Math.max(bounds.min, Math.min(bounds.max, mainStartH + dy));
    setMainHeight(newH);
  };
  const mainUp = () => {
    if (!mainDrag) return;
    mainDrag = false;
    document.body.classList.remove('dragging');
  };

  bridge.addEventListener('mousedown', mainDown);
  bridgeRight.addEventListener('mousedown', mainDown);

  // ─── Chatbot-split drag (small gap inside the chat zone) ───
  let chatDrag = false, chatStartY = 0, chatStartH = 0;

  const chatDown = (e) => {
    chatDrag    = true;
    chatStartY  = e.clientY;
    chatStartH  = chatInput.offsetHeight;
    document.body.classList.add('chat-dragging');
    e.preventDefault();
    e.stopPropagation();
  };
  const chatMove = (e) => {
    if (!chatDrag) return;
    const dy = e.clientY - chatStartY;
    const zoneH = chatZone.offsetHeight;
    const maxH = Math.max(MIN_CHAT_INPUT, zoneH * MAX_CHAT_INPUT_RATIO - CHAT_SMALL_GAP);
    const newH = Math.max(MIN_CHAT_INPUT, Math.min(maxH, chatStartH + dy));
    chatInput.style.height = newH + 'px';
  };
  const chatUp = () => {
    if (!chatDrag) return;
    chatDrag = false;
    document.body.classList.remove('chat-dragging');
  };

  chatbotDivider.addEventListener('mousedown', chatDown);

  // Single mousemove / mouseup that fans out to both drags
  document.addEventListener('mousemove', (e) => { mainMove(e); chatMove(e); });
  document.addEventListener('mouseup',   ()  => { mainUp();    chatUp();    });

  window.addEventListener('resize', clampAndPlace);

  // ─── Mode toggles (help, stealth, cmd, menu, config, stats) ───
  const modeLabel   = document.getElementById('bridgeModeLabel');
  const MODE_LABELS = { help: 'Help', stealth: 'Stealth' };

  const currentMode = () => {
    for (const c of document.body.classList) {
      if (c.endsWith('-mode')) return c.slice(0, -5);
    }
    return null;
  };
  const setMode = (mode) => {
    [...document.body.classList]
      .filter(c => c.endsWith('-mode'))
      .forEach(c => document.body.classList.remove(c));
    if (mode) {
      document.body.classList.add(mode + '-mode');
      modeLabel.textContent = MODE_LABELS[mode] || '';
    } else {
      modeLabel.textContent = '';
    }
  };
  document.querySelectorAll('.spine-button[data-mode-button]').forEach(btn => {
    const mode = btn.dataset.modeButton;
    btn.addEventListener('click', () => {
      setMode(currentMode() === mode ? null : mode);
    });
  });

  // ─── Initial layout: 30/70 main split, then enforce icon clearance ───
  const availableH = window.innerHeight - 32 - bridge.getBoundingClientRect().height;
  setMainHeight(availableH * 0.30);
  clampAndPlace();
})();
</script>

</body>
</html>
