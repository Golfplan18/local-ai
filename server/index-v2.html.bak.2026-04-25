<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Ora — v2 mockup</title>
<style>
  :root {
    --interface-bg: #1e1f29;
    --pane-bg:      #282a36;
    --pane-border:  #44475a;
    --fg-quiet:     rgba(248, 248, 242, 0.60);
    --fg-bright:    rgba(248, 248, 242, 1);
    --rule-line:    rgba(68, 71, 90, 0.10);
    --dot-grid:     rgba(68, 71, 90, 0.18);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--interface-bg);
    color: var(--fg-quiet);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
    overflow: hidden;
  }

  button { font: inherit; color: inherit; background: none; border: none; }

  /* ── Shell layout ──────────────────────────────────── */
  .ora-shell {
    display: grid;
    grid-template-columns: 1fr 84px 1fr;
    gap: 16px;
    padding: 16px;
    height: 100vh;
  }

  /* ── Panes (recessed surfaces) ─────────────────────── */
  .pane {
    background: var(--pane-bg);
    border: 2px solid var(--pane-border);
    border-radius: 6px;
    box-shadow:
      inset 6px 6px 14px rgba(0, 0, 0, 0.50),
      inset -1px -1px 0 rgba(255, 255, 255, 0.04);
    overflow: hidden;
    position: relative;
  }

  /* ── Left pane: output | divider | input ──────────── */
  .left-pane {
    display: flex;
    flex-direction: column;
  }

  .output-area {
    flex: 1;
    min-height: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 31px,
      var(--rule-line) 31px,
      var(--rule-line) 32px
    );
  }

  .divider {
    height: 10px;
    flex-shrink: 0;
    cursor: ns-resize;
    position: relative;
  }
  .divider::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 2px;
    border-radius: 1px;
    background: var(--pane-border);
    opacity: 0.45;
    transition: opacity 0.12s, height 0.12s, width 0.12s;
  }
  .divider:hover::before {
    opacity: 0.85;
    height: 3px;
    width: 56px;
  }
  body.dragging .divider::before {
    opacity: 0.95;
    height: 3px;
    width: 56px;
  }

  .input-area {
    height: 160px;
    flex-shrink: 0;
    padding: 14px 18px 16px;
  }
  .input-area textarea {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    color: var(--fg-bright);
    font-family: inherit;
    font-size: 14px;
    line-height: 1.5;
  }

  /* ── Right pane: dot grid ──────────────────────────── */
  .right-pane {
    background-image:
      radial-gradient(var(--dot-grid) 1.4px, transparent 1.6px);
    background-size: 24px 24px;
    background-position: 12px 12px;
  }

  /* ── Spine (no bg, no border, no shadow) ──────────── */
  .spine {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 18px 0;
  }

  .spine-top, .spine-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .spine-bottom { margin-top: auto; }

  .spine-logo {
    width: 28px;
    margin-bottom: 10px;
    color: var(--fg-quiet);
  }
  .spine-logo svg { display: block; width: 100%; height: auto; }

  /* ── Spine buttons (raised) ────────────────────────── */
  .spine-button {
    width: 44px;
    height: 44px;
    border-radius: 9px;
    background: var(--pane-bg);
    border: 1px solid var(--pane-border);
    color: var(--fg-quiet);
    box-shadow:
      3px 4px 7px rgba(0, 0, 0, 0.50),
      inset 1px 1px 0 rgba(255, 255, 255, 0.05);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.12s, transform 0.08s, box-shadow 0.08s;
  }
  .spine-button:hover { color: var(--fg-bright); }
  .spine-button:active {
    transform: translate(1px, 1px);
    box-shadow:
      2px 2px 4px rgba(0, 0, 0, 0.40),
      inset 1px 1px 0 rgba(255, 255, 255, 0.04);
  }
  .spine-button svg { width: 22px; height: 22px; display: block; }

  /* ── Central submit O (raised, primary) ────────────── */
  .spine-submit {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--pane-bg);
    border: 1px solid var(--pane-border);
    color: var(--fg-bright);
    box-shadow:
      6px 7px 16px rgba(0, 0, 0, 0.60),
      inset 1px 1px 0 rgba(255, 255, 255, 0.08);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: transform 0.08s, box-shadow 0.08s;
  }
  .spine-submit:active {
    transform: translate(calc(-50% + 1px), calc(-50% + 1px));
    box-shadow:
      4px 5px 10px rgba(0, 0, 0, 0.50),
      inset 1px 1px 0 rgba(255, 255, 255, 0.07);
  }
  .spine-submit svg { width: 42px; height: 42px; display: block; }

  /* ── Focus accessibility ───────────────────────────── */
  button:focus-visible, textarea:focus-visible {
    outline: 1px solid rgba(248, 248, 242, 0.35);
    outline-offset: 2px;
  }
</style>
</head>
<body>

<div class="ora-shell">

  <!-- LEFT PANE -->
  <div class="pane left-pane">
    <div class="output-area"></div>
    <div class="divider" id="divider"></div>
    <div class="input-area" id="inputArea">
      <textarea spellcheck="false"></textarea>
    </div>
  </div>

  <!-- SPINE -->
  <div class="spine">
    <div class="spine-top">

      <div class="spine-logo">
        <svg viewBox="0 0 290 766" xmlns="http://www.w3.org/2000/svg"
             fill="none" stroke="currentColor" stroke-width="18">
          <circle cx="145" cy="145" r="136"/>
          <circle cx="145" cy="145" r="91"/>
          <path d="M 54 428 A 91 91 0 0 1 236 428" stroke-linecap="butt"/>
          <rect x="45" y="328" width="18" height="200"
                fill="currentColor" stroke="none"/>
          <circle cx="145" cy="666" r="91"/>
          <rect x="227" y="566" width="18" height="200"
                fill="currentColor" stroke="none"/>
        </svg>
      </div>

      <button class="spine-button" type="button" aria-label="Command palette">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Mode selector">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Configuration">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <circle cx="9" cy="6" r="2.4" fill="var(--pane-bg)"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <circle cx="15" cy="12" r="2.4" fill="var(--pane-bg)"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
          <circle cx="11" cy="18" r="2.4" fill="var(--pane-bg)"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Analytics">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="6" y1="20" x2="6" y2="14"/>
          <line x1="12" y1="20" x2="12" y2="8"/>
          <line x1="18" y1="20" x2="18" y2="11"/>
          <line x1="3.5" y1="20" x2="20.5" y2="20"/>
        </svg>
      </button>
    </div>

    <button class="spine-submit" type="button" aria-label="Submit">
      <svg viewBox="0 0 290 290" xmlns="http://www.w3.org/2000/svg"
           fill="none" stroke="currentColor" stroke-width="18">
        <circle cx="145" cy="145" r="136"/>
        <circle cx="145" cy="145" r="91"/>
      </svg>
    </button>

    <div class="spine-bottom">
      <button class="spine-button" type="button" aria-label="Stealth">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2">
          <circle cx="12" cy="12" r="9"/>
          <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round"/>
        </svg>
      </button>

      <button class="spine-button" type="button" aria-label="Help">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2 -3 3 -3 3"/>
          <path d="M12 17h.01"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- RIGHT PANE -->
  <div class="pane right-pane"></div>

</div>

<script>
(() => {
  const divider = document.getElementById('divider');
  const inputArea = document.getElementById('inputArea');

  let dragging = false;
  let startY = 0;
  let startHeight = 0;

  const onDown = (e) => {
    dragging = true;
    startY = e.clientY;
    startHeight = inputArea.offsetHeight;
    document.body.classList.add('dragging');
    document.body.style.userSelect = 'none';
    document.body.style.cursor = 'ns-resize';
    e.preventDefault();
  };

  const onMove = (e) => {
    if (!dragging) return;
    const dy = e.clientY - startY;
    const maxH = window.innerHeight * 0.7;
    const newH = Math.max(80, Math.min(maxH, startHeight - dy));
    inputArea.style.height = newH + 'px';
  };

  const onUp = () => {
    if (!dragging) return;
    dragging = false;
    document.body.classList.remove('dragging');
    document.body.style.userSelect = '';
    document.body.style.cursor = '';
  };

  divider.addEventListener('mousedown', onDown);
  document.addEventListener('mousemove', onMove);
  document.addEventListener('mouseup', onUp);
})();
</script>

</body>
</html>
