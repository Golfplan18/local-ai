source: npm pack ajv@8.18.0; then browserify --standalone Ajv2020 of
  require('ajv/dist/2020').default; then terser for minification.
file: ajv2020.bundle.min.js
vendored: 2026-04-17 as part of WP-1.2a

Ajv 8 does not ship a prebuilt browser bundle for the 2020-12 validator in
its published tarball. We produce one here via browserify so we can stay
local-first (no CDN). The bundle exposes a UMD global `Ajv2020` on window.

To refresh:
  mkdir -p /tmp/ajv-rebuild && cd /tmp/ajv-rebuild
  npm install ajv@<new-version>
  cat > entry.js <<'EOF'
  var Ajv2020 = require('ajv/dist/2020').default;
  if (typeof window !== 'undefined') window.Ajv2020 = Ajv2020;
  if (typeof globalThis !== 'undefined') globalThis.Ajv2020 = Ajv2020;
  module.exports = Ajv2020;
  EOF
  npx browserify --standalone Ajv2020 entry.js -o ajv2020.bundle.js
  npx terser ajv2020.bundle.js -c -m --output ajv2020.bundle.min.js
  cp ajv2020.bundle.min.js ~/ora/server/static/ora-visual-compiler/vendor/ajv/
