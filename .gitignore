# Machine-specific configuration (generated by setup.sh from templates)
config.json
config/endpoints.json
config/models.json
config/interface.json
config/browser-sessions/
config/browser-profiles/
config/session-refresh.log

# User-generated content
mind.md
frameworks/personal/
agents/*.md
!agents/agent-registry.md

# Large binaries (each user downloads their own)
models/

# User-specific data
chromadb/
knowledge/
reconciliation/

# Generated per machine
ai
ai.app/
*.app/
config/icons/*.icns

# Machine-specific reports (generated by installer and upgrades)
docs/hardware-report.md
docs/upgrade-report*.md
docs/pre-upgrade-packages.txt

# Logs and caches
logs/
output/
*.log
__pycache__/
*.pyc
.DS_Store

# macOS launcher variants (generated per machine)
*.command
