#!/bin/bash
# maintain-rag-manifest.sh — Weekly RAG manifest maintenance.
# Verifies resources, regenerates indexes, recompiles manifest, checks health.
# Run during sleep-wake maintenance cycle.

set -uo pipefail

ORA_DIR="${HOME}/ora"
CONFIG_DIR="${ORA_DIR}/config"
SCRIPTS_DIR="${ORA_DIR}/scripts"
LOG_DIR="${ORA_DIR}/logs"
PYTHON="/opt/homebrew/bin/python3"

TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S")
LOG_FILE="${LOG_DIR}/rag-maintenance-$(date '+%Y-%m-%d').log"

log() {
    echo "[${TIMESTAMP}] $1" | tee -a "$LOG_FILE"
}

warn() {
    echo "[${TIMESTAMP}] WARNING: $1" | tee -a "$LOG_FILE"
}

WARNINGS=0

log "=== RAG Manifest Maintenance Start ==="

# 1. Verify ChromaDB accessible
log "Checking ChromaDB..."
if [ -f "${ORA_DIR}/chromadb/chroma.sqlite3" ]; then
    db_size=$(du -h "${ORA_DIR}/chromadb/chroma.sqlite3" | cut -f1)
    log "  ChromaDB database: ${db_size}"

    # Count documents in each collection
    doc_count=$($PYTHON -c "
import chromadb
client = chromadb.PersistentClient(path='${ORA_DIR}/chromadb')
for col in client.list_collections():
    print(f'  Collection {col.name}: {col.count()} documents')
" 2>/dev/null) || doc_count="  (count query failed)"
    log "$doc_count"
else
    warn "ChromaDB database not found at ${ORA_DIR}/chromadb/chroma.sqlite3"
    WARNINGS=$((WARNINGS + 1))
fi

# 2. Verify embedding model
log "Checking embedding model (Ollama)..."
if curl -s http://localhost:11434/api/tags > /dev/null 2>&1; then
    log "  Ollama endpoint responding"
else
    warn "Ollama not responding at localhost:11434"
    WARNINGS=$((WARNINGS + 1))
fi

# 3. Check approved-sources.md
log "Checking approved sources..."
if [ -f "${CONFIG_DIR}/approved-sources.md" ]; then
    source_count=$(grep "^|" "${CONFIG_DIR}/approved-sources.md" | grep -v "^|---" | grep -v "^| Source" | wc -l | tr -d ' ')
    log "  Approved sources: ${source_count} entries"
    if [ "$source_count" -eq 0 ]; then
        warn "Approved sources list is empty"
        WARNINGS=$((WARNINGS + 1))
    fi
    # Check if not modified in 30+ days
    source_mod=$(stat -f %m "${CONFIG_DIR}/approved-sources.md" 2>/dev/null || stat -c %Y "${CONFIG_DIR}/approved-sources.md")
    now=$(date +%s)
    age_days=$(( (now - source_mod) / 86400 ))
    if [ "$age_days" -gt 30 ]; then
        warn "Approved sources not modified in ${age_days} days — review recommended"
        WARNINGS=$((WARNINGS + 1))
    fi
else
    warn "approved-sources.md not found"
    WARNINGS=$((WARNINGS + 1))
fi

# 4. Check excluded-sources.md
log "Checking excluded sources..."
if [ ! -f "${CONFIG_DIR}/excluded-sources.md" ]; then
    log "  Creating empty excluded-sources.md"
    echo "# Excluded Sources Blocklist" > "${CONFIG_DIR}/excluded-sources.md"
fi

# 5. Regenerate modes-index.md
log "Regenerating indexes..."
if [ -f "${SCRIPTS_DIR}/generate-indexes.sh" ]; then
    bash "${SCRIPTS_DIR}/generate-indexes.sh" >> "$LOG_FILE" 2>&1
    log "  Indexes regenerated"
else
    warn "generate-indexes.sh not found"
    WARNINGS=$((WARNINGS + 1))
fi

# 6. Recompile manifest if needed
log "Checking manifest compilation..."
if [ -f "${SCRIPTS_DIR}/compile-rag-manifest.sh" ]; then
    bash "${SCRIPTS_DIR}/compile-rag-manifest.sh" >> "$LOG_FILE" 2>&1
else
    warn "compile-rag-manifest.sh not found"
    WARNINGS=$((WARNINGS + 1))
fi

# 7. Token count on compiled manifest
if [ -f "${CONFIG_DIR}/rag-manifest-compiled.md" ]; then
    token_est=$(wc -w < "${CONFIG_DIR}/rag-manifest-compiled.md")
    log "  Compiled manifest: ~${token_est} words"
    if [ "$token_est" -gt 4000 ]; then
        warn "Compiled manifest exceeds 4000 word estimate (${token_est})"
        WARNINGS=$((WARNINGS + 1))
    fi
fi

# 8. Check conversation collection growth
log "Checking conversation collection health..."
conv_dir="${HOME}/Documents/conversations"
if [ -d "$conv_dir" ]; then
    recent_convos=$(find "$conv_dir" -name "*.md" -mtime -7 2>/dev/null | wc -l | tr -d ' ')
    log "  Conversations in last 7 days: ${recent_convos}"
    if [ "$recent_convos" -eq 0 ]; then
        warn "No new conversations in 7+ days — collection may be stale"
        WARNINGS=$((WARNINGS + 1))
    fi
fi

# 9. RAG manifest reconciliation (Phase 13.3)
log "Running RAG manifest reconciliation..."
if [ -f "${CONFIG_DIR}/rag-manifest.md" ]; then
    $PYTHON -c "
import os, re

manifest_path = '${CONFIG_DIR}/rag-manifest.md'
vault_path = os.path.expanduser('~/Documents/vault')
chromadb_path = os.path.expanduser('~/ora/chromadb')
modes_dir = os.path.expanduser('~/ora/modes')
frameworks_dir = os.path.expanduser('~/ora/frameworks/book')
issues = []

with open(manifest_path, 'r') as f:
    manifest = f.read()

# Check vault-knowledge resource: vault directory exists and has files
if os.path.isdir(vault_path):
    vault_files = sum(1 for r, d, f in os.walk(vault_path) for x in f if x.endswith('.md') and not r.startswith(os.path.join(vault_path, '.')))
    print(f'  Vault knowledge: {vault_files} markdown files')
else:
    issues.append('Vault directory not found: ' + vault_path)

# Check modes-directory resource
if os.path.isdir(modes_dir):
    mode_count = len([f for f in os.listdir(modes_dir) if f.endswith('.md')])
    print(f'  Modes directory: {mode_count} mode files')
else:
    issues.append('Modes directory not found: ' + modes_dir)

# Check framework-library resource
if os.path.isdir(frameworks_dir):
    fw_count = len([f for f in os.listdir(frameworks_dir) if f.endswith('.md')])
    print(f'  Framework library: {fw_count} framework files')
else:
    issues.append('Frameworks directory not found: ' + frameworks_dir)

# Check ChromaDB collections match manifest descriptions
try:
    import chromadb
    client = chromadb.PersistentClient(path=chromadb_path)
    collections = {c.name: c.count() for c in client.list_collections()}
    # Manifest describes: knowledge, conversations
    for expected in ['knowledge', 'conversations']:
        if expected in collections:
            print(f'  ChromaDB {expected}: {collections[expected]} records')
        else:
            issues.append(f'ChromaDB collection \"{expected}\" not found but described in manifest')
    # Check for collections not in manifest
    described = {'knowledge', 'conversations', 'conversations-incognito'}
    for col_name in collections:
        if col_name not in described:
            issues.append(f'ChromaDB collection \"{col_name}\" exists but not in manifest')
except Exception as e:
    issues.append(f'ChromaDB check failed: {e}')

if issues:
    print('  RECONCILIATION ISSUES:')
    for issue in issues:
        print(f'    - {issue}')
    exit(1)
else:
    print('  Manifest reconciliation: OK')
" 2>&1 | tee -a "$LOG_FILE"
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        warn "RAG manifest reconciliation found issues — see above"
        WARNINGS=$((WARNINGS + 1))
    fi
else
    warn "rag-manifest.md not found"
    WARNINGS=$((WARNINGS + 1))
fi

# Summary
log "=== Maintenance Complete ==="
log "Warnings: ${WARNINGS}"
if [ "$WARNINGS" -gt 0 ]; then
    log "HUMAN REVIEW RECOMMENDED — ${WARNINGS} warning(s) logged"
fi
