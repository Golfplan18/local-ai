      { "id": "M", "label": "Monitoring coverage" }
    ],
    "links": [
      { "from": "V", "to": "T", "polarity": "+" },
      { "from": "T", "to": "F", "polarity": "+", "delay": true },
      { "from": "F", "to": "V", "polarity": "-" },
      { "from": "M", "to": "F", "polarity": "-" }
    ],
