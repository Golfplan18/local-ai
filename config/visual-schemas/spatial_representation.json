{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ora.local/schemas/spatial_representation.json",
  "title": "Ora Visual Spatial Representation",
  "description": "Optional spatial-native representation per Protocol v0.2 \u00a710.1. Captures Tversky-style correspondence entities, relationships, clusters, and hierarchy. Links to typed-diagram elements via spec_ref.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entities"],
  "properties": {
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "position", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "position": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2,
            "description": "[x, y] coordinates. Coordinate system is implementation-defined; compiler normalizes."
          },
          "label": { "type": "string", "minLength": 1 },
          "spec_ref": {
            "type": "string",
            "description": "Optional reference to a node id inside the typed spec."
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "type"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["causal", "associative", "hierarchical", "temporal"]
          },
          "strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "spec_ref": { "type": "string" }
        }
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["members", "label"],
        "properties": {
          "members": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "hierarchy": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parent", "children", "type"],
        "properties": {
          "parent": { "type": "string", "minLength": 1 },
          "children": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "type": {
            "type": "string",
            "enum": ["abstraction", "containment", "composition"]
          }
        }
      }
    }
  }
}
