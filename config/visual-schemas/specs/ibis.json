{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ora.local/schemas/specs/ibis.json",
  "title": "IBIS argument diagram spec (ARGUMENT family)",
  "description": "Per Protocol \u00a73.12. Grammar invariants ('idea.responds_to->question', 'pro.supports->idea', 'con.objects_to->idea', 'question.questions->any') are enforced structurally by the integrity checker; here we enforce the node/edge type enums.",
  "type": "object",
  "additionalProperties": false,
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "text"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["question", "idea", "pro", "con"]
          },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["responds_to", "supports", "objects_to", "questions"]
          }
        }
      }
    }
  }
}
