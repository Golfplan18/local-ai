{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ora.local/schemas/specs/stock_and_flow.json",
  "title": "Stock-and-flow diagram spec (CAUSAL family, XMILE-aligned)",
  "description": "Per Protocol \u00a73.4. Flow endpoint resolution, auxiliary DAG-ness, and unit consistency are enforced by the integrity checker.",
  "type": "object",
  "additionalProperties": false,
  "required": ["stocks", "flows"],
  "properties": {
    "stocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "initial": { "type": "number" },
          "unit": { "type": "string" }
        }
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "from", "to"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "rate": { "type": "string" },
          "unit": { "type": "string" }
        }
      }
    },
    "clouds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "auxiliaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "expression": { "type": "string" }
        }
      }
    },
    "info_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
