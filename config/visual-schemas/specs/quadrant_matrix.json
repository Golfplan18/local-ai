{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ora.local/schemas/specs/quadrant_matrix.json",
  "title": "2\u00d72 / scenario-planning quadrant matrix spec (DECISION family)",
  "description": "Per Protocol \u00a73.10. axes_independence_rationale is hard-required; for scenario_planning subtype the integrity checker additionally enforces quadrant narrative presence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["subtype", "x_axis", "y_axis", "quadrants", "axes_independence_rationale"],
  "properties": {
    "subtype": {
      "type": "string",
      "enum": ["strategic_2x2", "scenario_planning"]
    },
    "x_axis": { "$ref": "#/$defs/axis" },
    "y_axis": { "$ref": "#/$defs/axis" },
    "quadrants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["TL", "TR", "BL", "BR"],
      "properties": {
        "TL": { "$ref": "#/$defs/quadrant" },
        "TR": { "$ref": "#/$defs/quadrant" },
        "BL": { "$ref": "#/$defs/quadrant" },
        "BR": { "$ref": "#/$defs/quadrant" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "x", "y"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "x": { "type": "number", "minimum": 0, "maximum": 1 },
          "y": { "type": "number", "minimum": 0, "maximum": 1 },
          "note": { "type": "string" }
        }
      }
    },
    "axes_independence_rationale": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "low_label", "high_label"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "low_label": { "type": "string", "minLength": 1 },
        "high_label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "quadrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "narrative": { "type": "string" },
        "action": { "type": "string" },
        "indicators": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
