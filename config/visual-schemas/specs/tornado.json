{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ora.local/schemas/specs/tornado.json",
  "title": "Tornado / sensitivity diagram spec (QUANT family)",
  "description": "Horizontal-bar sensitivity diagram per Protocol \u00a73.2. Added in v0.2. Parameters render as horizontal bars around a base-case center line; ordering by swing is enforced downstream.",
  "type": "object",
  "additionalProperties": false,
  "required": ["base_case_label", "base_case_value", "outcome_variable", "outcome_units", "parameters", "sort_by"],
  "properties": {
    "base_case_label": { "type": "string", "minLength": 1 },
    "base_case_value": { "type": "number" },
    "outcome_variable": { "type": "string", "minLength": 1 },
    "outcome_units": { "type": "string", "minLength": 1 },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "low_value", "high_value", "outcome_at_low", "outcome_at_high"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "low_value": { "type": "number" },
          "high_value": { "type": "number" },
          "low_label": { "type": "string" },
          "high_label": { "type": "string" },
          "outcome_at_low": { "type": "number" },
          "outcome_at_high": { "type": "number" }
        }
      }
    },
    "sort_by": {
      "type": "string",
      "enum": ["swing", "high_impact", "custom"]
    }
  }
}
