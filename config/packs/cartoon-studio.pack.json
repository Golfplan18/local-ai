{
  "pack_name": "Cartoon Studio",
  "pack_version": "1.0.0",
  "ora_compatibility": ">=0.7.0",
  "author": {
    "name": "Ora",
    "url": "https://ora.local"
  },
  "description": "Comic + cartoon authoring \u2014 speech bubbles, thought bubbles, caption boxes, and panel-grid templates for 2-panel, 4-panel, and manga-style pages.",
  "toolbars": [
    {
      "id": "cartoon-studio",
      "label": "Cartoon Studio",
      "default_dock": "left",
      "default_icon_size": "small",
      "items": [
        {
          "id": "speech",
          "icon": "message-circle",
          "label": "Speech bubble",
          "shortcut": "B",
          "binding": "tool:speech_bubble"
        },
        {
          "id": "thought",
          "icon": "cloud",
          "label": "Thought bubble",
          "shortcut": "Shift+B",
          "binding": "tool:thought_bubble"
        },
        {
          "id": "shout",
          "icon": "zap",
          "label": "Shout bubble",
          "binding": "tool:shout_bubble"
        },
        {
          "id": "caption",
          "icon": "rectangle-horizontal",
          "label": "Caption box",
          "shortcut": "C",
          "binding": "tool:caption_box"
        },
        {
          "id": "panel",
          "icon": "square",
          "label": "Panel frame",
          "shortcut": "P",
          "binding": "tool:rect"
        },
        {
          "id": "text",
          "icon": "type",
          "label": "Text",
          "shortcut": "T",
          "binding": "tool:text"
        },
        {
          "id": "generate-art",
          "icon": "sparkles",
          "label": "Generate panel art",
          "shortcut": "Shift+G",
          "binding": "capability:image_generates"
        },
        {
          "id": "restyle",
          "icon": "palette",
          "label": "Restyle as comic",
          "binding": "capability:image_styles",
          "enabled_when": "image_present"
        },
        {
          "id": "ask-ora",
          "icon": "wand-2",
          "label": "Ask Ora",
          "shortcut": "Shift+A",
          "binding": "tool:ask_ora"
        }
      ]
    }
  ],
  "prompt_templates": [
    {
      "id": "panel-art",
      "slash_command": "/panel-art",
      "label": "Generate panel art",
      "template": "Generate one comic-book panel illustrating: {{scene}}. Style: {{style}}. Include strong outlines and flat color fills. Leave clear sky/wall space at the top for a speech bubble.",
      "variables": [
        {
          "name": "scene",
          "type": "text",
          "label": "What's happening"
        },
        {
          "name": "style",
          "type": "enum",
          "label": "Style",
          "default": "western comic",
          "options": [
            "western comic",
            "manga",
            "graphic novel",
            "newspaper strip",
            "kid-friendly cartoon"
          ]
        }
      ],
      "capability_route": "image_generates"
    },
    {
      "id": "restyle-as-comic",
      "slash_command": "/comic-style",
      "label": "Restyle as comic",
      "template": "Restyle this image as a comic-book illustration. Strong black outlines, flat color blocks, halftone shading, no photographic detail. Preserve the subject and composition; only change the rendering.",
      "variables": [],
      "capability_route": "image_styles"
    },
    {
      "id": "write-caption",
      "slash_command": "/caption",
      "label": "Write a caption",
      "template": "Write a 1-2 sentence narrator caption for this comic panel. Tone: {{tone}}. Subject: {{subject}}.",
      "variables": [
        {
          "name": "subject",
          "type": "text",
          "label": "What's in the panel"
        },
        {
          "name": "tone",
          "type": "enum",
          "label": "Tone",
          "default": "dramatic",
          "options": [
            "dramatic",
            "wry",
            "noir",
            "wholesome",
            "ironic"
          ]
        }
      ],
      "gear_preference": 2
    }
  ],
